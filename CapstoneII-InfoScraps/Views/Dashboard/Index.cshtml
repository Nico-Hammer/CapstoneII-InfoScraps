@model List<CapstoneII_InfoScraps.Models.DB.Account>
@{
    ViewData["Title"] = "Dashboard";
}

@if (Model != null && Model.Any())
{
    @foreach (var account in Model)
    {
        var user = account.User;
        var scrapeCount = account.Scraped_Data.Count;
        var uniqueDomains = account.Scraped_Data.Select(s => new Uri(s.Website).Host).Distinct().Count();

        <div class="is-page-header">
            <h1>Dashboard</h1>
            <div class="is-page-actions">
                <a class="is-btn is-btn-primary" asp-controller="Scraper" asp-action="Index">Scrape</a>
                <a class="is-btn is-btn-export" asp-controller="Dashboard" asp-action="ExportCsv">Export All CSV</a>
            </div>
        </div>

        <!-- Stats Grid -->
        <div class="is-stats-grid">
            <div class="is-stat-card">
                <div class="is-stat-value">@scrapeCount</div>
                <div class="is-stat-label">Total Leads</div>
            </div>
            <div class="is-stat-card">
                <div class="is-stat-value">@uniqueDomains</div>
                <div class="is-stat-label">Domains Scraped</div>
            </div>
            <div class="is-stat-card">
                <div class="is-stat-value">@account.Email_Templates.Count</div>
                <div class="is-stat-label">Email Templates</div>
            </div>
        </div>

        <!-- Scraped Data Table -->
        <div class="is-card is-card-static">
            <div class="is-page-header" style="margin-bottom: var(--space-md);">
                <h3>Scraped Leads</h3>
                <div class="is-search-bar" style="margin-bottom: 0; flex: 1; max-width: 400px;">
                    <span class="is-search-icon">&#128269;</span>
                    <input type="text" class="is-search-input" id="searchInput" placeholder="Search leads..." />
                </div>
            </div>

            @if (account.Scraped_Data.Any())
            {
                <table class="is-table" id="leadsTable">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Email</th>
                            <th>Name</th>
                            <th>Phone</th>
                            <th>Website</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var scrape in account.Scraped_Data.OrderByDescending(s => s.Date_Of_Scrape))
                        {
                            <tr>
                                <td class="is-date">@scrape.Date_Of_Scrape.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="is-email">@scrape.Scraped_Email</td>
                                <td>@scrape.Scraped_Name</td>
                                <td>@scrape.Scraped_Phone</td>
                                <td class="is-website"><a href="@scrape.Website" target="_blank">@scrape.Website</a></td>
                                <td class="is-actions">
                                    <button type="button" class="is-btn is-btn-sm is-btn-primary"
                                            onclick="editLead(@scrape.Id, '@Html.Raw(scrape.Scraped_Name?.Replace("'", "\\'") ?? "")', '@Html.Raw(scrape.Scraped_Email?.Replace("'", "\\'") ?? "")', '@Html.Raw(scrape.Scraped_Phone?.Replace("'", "\\'") ?? "")')">
                                        Edit
                                    </button>
                                    <button type="button" class="is-btn is-btn-sm is-btn-danger"
                                            onclick="confirmDeleteLead(@scrape.Id, '@Html.Raw(scrape.Scraped_Name?.Replace("'", "\\'") ?? "this lead")')">
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="is-no-data">
                    No leads scraped yet. Click "Scrape" to get started.
                </div>
            }
        </div>

        <!-- Edit Lead Modal -->
        <div class="modal fade" id="editLeadModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content is-modal-content">
                    <div class="modal-header is-modal-header">
                        <h5 class="modal-title">Edit Lead</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-controller="Dashboard" asp-action="Edit" method="post">
                        <div class="modal-body is-modal-body">
                            <input type="hidden" name="id" id="editLeadId" />
                            <div class="mb-3">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control is-input" name="name" id="editLeadName" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control is-input" name="email" id="editLeadEmail" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Phone</label>
                                <input type="text" class="form-control is-input" name="phone" id="editLeadPhone" />
                            </div>
                        </div>
                        <div class="modal-footer is-modal-footer">
                            <button type="button" class="is-btn is-btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="is-btn is-btn-primary">Save</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Delete Lead Modal -->
        <div class="modal fade" id="deleteLeadModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content is-modal-content">
                    <div class="modal-header is-modal-header">
                        <h5 class="modal-title">Delete Lead</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-controller="Dashboard" asp-action="Delete" method="post">
                        <div class="modal-body is-modal-body">
                            <input type="hidden" name="id" id="deleteLeadId" />
                            <p>Are you sure you want to delete <strong id="deleteLeadName"></strong>? This cannot be undone.</p>
                        </div>
                        <div class="modal-footer is-modal-footer">
                            <button type="button" class="is-btn is-btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="is-btn is-btn-danger">Delete</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="is-auth-container">
        <h1>Not Logged In</h1>
        <p style="color: var(--gray-400);">Please log in to access your dashboard.</p>
        <a class="is-btn is-btn-primary" asp-controller="Login" asp-action="Index">Log In</a>
    </div>
}

@section Scripts {
    <script>
        // Search functionality for leads table
        var searchInput = document.getElementById('searchInput');
        if (searchInput) {
            searchInput.addEventListener('input', function () {
                var filter = this.value.toLowerCase();
                var rows = document.querySelectorAll('#leadsTable tbody tr');
                rows.forEach(function (row) {
                    var text = row.textContent.toLowerCase();
                    row.style.display = text.includes(filter) ? '' : 'none';
                });
            });
        }

        function editLead(id, name, email, phone) {
            document.getElementById('editLeadId').value = id;
            document.getElementById('editLeadName').value = name;
            document.getElementById('editLeadEmail').value = email;
            document.getElementById('editLeadPhone').value = phone;
            new bootstrap.Modal(document.getElementById('editLeadModal')).show();
        }

        function confirmDeleteLead(id, name) {
            document.getElementById('deleteLeadId').value = id;
            document.getElementById('deleteLeadName').textContent = name;
            new bootstrap.Modal(document.getElementById('deleteLeadModal')).show();
        }
    </script>
}
